# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=AegisAI
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=postgresql://postgres:your_secure_password_here@db:5432/aegisai_db
POSTGRES_USER=your_postgres_username_here
POSTGRES_PASSWORD=your_secure_password_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY= # Required! Generate with: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DOCUMENT_SHARE_EXPIRE_DAYS=7

# ── Stripe (optional — leave blank to run without billing) ────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# ── LLM Provider (OpenAI-compatible — works with any provider) ────────────────
# Used by both the Guard module (prompt responses) and the RAG module (QA chain).
#
# Option A — OpenAI (default):
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=           ← leave empty
#   LLM_MODEL=gpt-4o-mini
#
# Option B — Ollama (local, free, no API key needed):
#   LLM_API_KEY=ollama
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.2      ← or mistral, phi3, gemma2 …
#   # To use the regulatory fine-tuned adapter, publish it to HF and set:
#   # LLM_MODEL=hf.co/yourusername/Llama-3.2-3B-Regulatory-QA-Adapter
#
# Option C — Groq (free tier, fast):
#   LLM_API_KEY=gsk_...
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30.0

# ── Module 2: LLM Guard ───────────────────────────────────────────────────────
GUARD_SANITIZATION_LEVEL=medium
GUARD_MAX_PROMPT_LENGTH=2000
GUARD_RATE_LIMIT_REQUESTS=60
GUARD_RATE_LIMIT_WINDOW_SECONDS=60

# ── Shared infrastructure ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Module 1: AI System bulk import ───────────────────────────────────────────
AI_SYSTEM_BULK_IMPORT_MAX_BYTES=5242880
AI_SYSTEM_BULK_IMPORT_MAX_ROWS=5000

# ── Module 3: RAG Intelligence ────────────────────────────────────────────────
S3_BUCKET_NAME=
FAISS_INDEX_PATH=faiss_index
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ── MLflow (RAG query tracking) ───────────────────────────────────────────────
# Leave empty to store runs locally in ./mlruns (default).
# Set to a remote server for team-shared tracking, e.g.:
#   MLFLOW_TRACKING_URI=http://localhost:5000
#
# To view the MLflow UI locally:
#   1. pip install mlflow   (already in requirements.txt)
#   2. mlflow ui --port 5001
#   3. Open http://localhost:5001
MLFLOW_TRACKING_URI=
